{
  "name": "ai-voice-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "build":      "npm -w @nkirit/ai-voice run build && npm -w @nkirit/ai-voice-demo run build",
    "build:lib":  "npm -w @nkirit/ai-voice run build",
    "build:demo": "npm -w @nkirit/ai-voice-demo run build",
    "dev:demo":   "npm -w @nkirit/ai-voice-demo run dev",
    "test":       "npm -w packages/ai-voice run test",
    "typecheck":  "tsc -b packages/ai-voice --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": { "node": ">=18.18" }
}
